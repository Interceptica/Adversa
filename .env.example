# Copy to .env and fill in real values.
# NEVER commit .env to version control.

# LLM provider API key (Novita, Anthropic, or any Anthropic-compatible provider)
LLM_API_KEY=your-api-key-here

# Optional: custom base URL for Anthropic-compatible providers (e.g. Novita)
# Leave unset to use Anthropic directly.
# LLM_BASE_URL=https://api.novita.ai/v3/openai

# Optional: override the default model
# LLM_MODEL_NAME=claude-sonnet-4-6
